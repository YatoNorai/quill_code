{
  "id": "gruvbox_light",
  "name": "Gruvbox Light",
  "dark": false,
  "colors": {
    "background": "#FBF1C7",
    "lineNumberBackground": "#F2E5BC",
    "textNormal": "#3C3836",
    "lineNumber": "#928374",
    "lineNumberCurrent": "#3C3836",
    "cursor": "#076678",
    "selectionColor": "#D5C4A133",
    "keyword": "#9D0006",
    "string": "#79740E",
    "comment": "#928374",
    "number": "#B57614",
    "operator": "#427B58",
    "identifier": "#3C3836",
    "function": "#076678",
    "type": "#8F3F71",
    "annotation": "#AF3A03",
    "blockLine": "#D5C4A1",
    "completionBackground": "#F2E5BC",
    "ghostTextForeground": "#928374",
    "currentLineBackground": "#EBDBB2",
    "activeBlockHighlight": "#EBDBB2BB",
    "searchMatchBackground": "#B5761433",
    "searchMatchBorder": "#B57614"
  },
  "lineHighlight": {
    "style": "fill",
    "fillColor": "#EBDBB2",
    "strokeColor": "#D5C4A1",
    "accentColor": "#076678",
    "activeBlockColor": "#EBDBB299"
  },
  "blockLines": {
    "color": "#D5C4A188",
    "activeColor": "#076678FF",
    "width": 1.0,
    "activeWidth": 1.5,
    "colorMode": "single",
    "inactiveOpacity": 0.5,
    "program": [
      { "op": "line", "length": 8 },
      { "op": "gap",  "length": 4 }
    ],
    "endCap": { "type": "none" },
    "activeProgram": [
      { "op": "line", "fill": true }
    ],
    "activeEndCap": { "type": "curve", "radius": 8, "tick": 6 }
  },
  "bracketPair": {
    "fillColor": "#0766781A",
    "borderColor": "#07667880",
    "borderWidth": 1.2,
    "radius": 2.0
  },
  "indentDots": {
    "visible": false,
    "color": "#92837444",
    "size": 1.5,
    "mode": "indentOnly"
  }
}
