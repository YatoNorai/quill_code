{
  "id": "neon_synthwave",
  "name": "Neon Synthwave",
  "dark": true,
  "colors": {
    "background": "#1E1E2E",
    "lineNumberBackground": "#181825",
    "textNormal": "#CDD6F4",
    "lineNumber": "#6C7086",
    "lineNumberCurrent": "#CDD6F4",
    "cursor": "#89B4FA",
    "selectionColor": "#89B4FA33",
    "keyword": "#CBA6F7",
    "string": "#A6E3A1",
    "comment": "#6C7086",
    "number": "#FAB387",
    "operator": "#89DCEB",
    "identifier": "#CDD6F4",
    "function": "#89B4FA",
    "type": "#F38BA8",
    "annotation": "#F5C2E7",
    "blockLine": "#313244",
    "completionBackground": "#1E1E2E",
    "ghostTextForeground": "#6C7086",
    "currentLineBackground": "#313244",
    "activeBlockHighlight": "#313244BB",
    "searchMatchBackground": "#F9E2AF33",
    "searchMatchBorder": "#F9E2AF"
  },
  "lineHighlight": {
    "style": "fill",
    "fillColor": "#1A0A2E",
    "strokeColor": "#2A0A3A",
    "accentColor": "#FF00FF",
    "activeBlockColor": "#1A0A2E99"
  },
  "blockLines": {
    "color": "#2A0A3A66",
    "activeColor": "#FF00FFFF",
    "width": 1.0,
    "activeWidth": 2.0,
    "colorMode": "rainbow",
    "inactiveOpacity": 0.6,
    "rainbowColors": [
      "#FF00FF",
      "#00FFFF",
      "#FF3366",
      "#AAFF00",
      "#FF9900",
      "#9900FF"
    ],
    "program": [
      {
        "op": "wave",
        "height": 10,
        "period": 8,
        "amplitude": 2.5
      },
      {
        "op": "cross",
        "size": 2,
        "gap": 6
      }
    ],
    "endCap": {
      "type": "none"
    },
    "activeProgram": [
      {
        "op": "line",
        "fill": true
      }
    ],
    "activeEndCap": {
      "type": "curve",
      "radius": 7,
      "tick": 6
    }
  },
  "bracketPair": {
    "fillColor": "#89B4FA1A",
    "borderColor": "#89B4FA80",
    "borderWidth": 1.2,
    "radius": 2.0
  },
  "indentDots": {
    "visible": false,
    "color": "#6C708644",
    "size": 1.5,
    "mode": "indentOnly"
  }
}