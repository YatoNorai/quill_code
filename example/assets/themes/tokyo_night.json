{
  "id": "tokyo_night",
  "name": "Tokyo Night",
  "dark": true,
  "colors": {
    "background": "#1E1E2E",
    "lineNumberBackground": "#181825",
    "textNormal": "#CDD6F4",
    "lineNumber": "#6C7086",
    "lineNumberCurrent": "#CDD6F4",
    "cursor": "#89B4FA",
    "selectionColor": "#89B4FA33",
    "keyword": "#CBA6F7",
    "string": "#A6E3A1",
    "comment": "#6C7086",
    "number": "#FAB387",
    "operator": "#89DCEB",
    "identifier": "#CDD6F4",
    "function": "#89B4FA",
    "type": "#F38BA8",
    "annotation": "#F5C2E7",
    "blockLine": "#313244",
    "completionBackground": "#1E1E2E",
    "ghostTextForeground": "#6C7086",
    "currentLineBackground": "#313244",
    "activeBlockHighlight": "#313244BB",
    "searchMatchBackground": "#F9E2AF33",
    "searchMatchBorder": "#F9E2AF"
  },
  "lineHighlight": {
    "style": "fill",
    "fillColor": "#1F2335",
    "strokeColor": "#292E42",
    "accentColor": "#7AA2F7",
