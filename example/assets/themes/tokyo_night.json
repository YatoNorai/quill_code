      },
      {
        "op": "gap",
        "length": 4
      }
    ],
    "endCap": {
      "type": "none"
    },
    "activeProgram": [
      {
        "op": "line",
        "fill": true
      }
    ],
    "activeEndCap": {
      "type": "curve",
      "radius": 8,
      "tick": 6
    }
  },
  "bracketPair": {
    "fillColor": "#89B4FA1A",
    "borderColor": "#89B4FA80",
    "borderWidth": 1.2,
    "radius": 2.0
  },
  "indentDots": {
    "visible": false,
    "color": "#6C708644",
    "size": 1.5,
    "mode": "indentOnly"
  }
